# ── Anthropic (Claude AI) ─────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxx

# ── OpenAI (DALL-E image generation) ─────────────────────────────
OPENAI_API_KEY=sk-xxx

# ── Sendblue (SMS / iMessage) ─────────────────────────────────────
SENDBLUE_API_KEY_ID=your_sendblue_api_key_id
SENDBLUE_API_SECRET_KEY=your_sendblue_api_secret_key
# Your Sendblue phone number (used as the from_number when sending)
SENDBLUE_PHONE_NUMBER=+1xxxxxxxxxx

# ── Pinecone (knowledge base) ─────────────────────────────────────
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_API_HOST=prod-1-data.ke.pinecone.io
PINECONE_ASSISTANT_NAME=randi-kb

# ── AWS (DynamoDB — conversation history) ─────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
# DynamoDB table name for conversation storage (create this table manually)
DYNAMODB_TABLE_NAME=ai-agent-example-tk

# ── Server ────────────────────────────────────────────────────────
PORT=3000

# ── Development gates ─────────────────────────────────────────────
# Only respond to these sender numbers (comma-separated, leave blank to respond to everyone)
# Test tenant: +15129799088
ALLOWED_SENDERS=+15129799088

# Sender numbers to never respond to (comma-separated)
IGNORED_SENDERS=
